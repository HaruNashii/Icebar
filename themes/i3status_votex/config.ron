// ╭─────────────────────────────────────────────────────────────────────────╮
// │   Votex Theme                                               	     │
// │                                                                         │
// │   LEFT:   SwayWorkspaces · FocusedWindow                                │
// │   CENTER: Cpu · CpuTemp · Ram · Clock (time + date)                     │
// │   RIGHT:  Tray · Keyboard · VolumeOutput · Power                        │
// │                                                                         │
// ╰─────────────────────────────────────────────────────────────────────────╯

BarConfig
(
    // ================= GENERAL =================
    display: None,
    bar_position: Up,
    floating_space: 0,
    increased_exclusive_bar_zone: 0,
    bar_check_reload_interval_ms: Some(1000),
    bar_side_spaces_size: 0,
