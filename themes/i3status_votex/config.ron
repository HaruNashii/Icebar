        ram_padding: 0,
        ram_text_size: 11,
        ram_text_color: RGB((255, 255, 255)),
        ram_text_orientation: Horizontal,
        ram_button_color: RGB((0, 0, 0)),
        ram_button_hovered_color: RGB((35, 42, 65)),
        ram_button_hovered_text_color: RGB((255, 255, 255)),
