// ╭─────────────────────────────────────────────────────────────────────────╮
// │   Votex Theme                                               	     │
// │                                                                         │
// │   LEFT:   SwayWorkspaces · FocusedWindow                                │
// │   CENTER: Cpu · CpuTemp · Ram · Clock (time + date)                     │
// │   RIGHT:  Tray · Keyboard · VolumeOutput · Power                        │
// │                                                                         │
// ╰─────────────────────────────────────────────────────────────────────────╯

BarConfig
(

    // ================= GENERAL =================
    general:
    (
        display: None,
        bar_position: Up,
        floating_space: 0,
        increased_exclusive_bar_zone: 0,
        bar_check_reload_interval_ms: Some(1000),
        bar_side_spaces_size: 0,
        bar_size: (0, 25),
        bar_border_radius: (0., 0., 0., 0.),
        bar_border_size: 0.0,
        bar_border_color: RGB((8, 57, 132)),
        bar_background_color: RGBA((0, 0, 0, 100)),
        font_family: "JetBrains Mono",
        font_style: "Bold",
        spacing_between_all_modules: 0,
        force_static_position_context_menu: None,
        left_modules: [SwayWorkspaces],
        center_modules: [],
        right_modules: [FocusedWindowSway, Cpu, Ram, VolumeOutput, CustomModule(0), Clock, CustomModule(1), Tray],
    ),


    // ================= GENERAL STYLE =================
//    general_style:
//    (
//        general_padding: Some(0),
//        general_text_size: Some(15),
//        general_text_orientation: Some(Horizontal),
