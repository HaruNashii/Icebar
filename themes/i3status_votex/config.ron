    [
        // ── MODULE 0 ── KEYBOARD LAYOUT
        // Left click cycles to next layout.
        (
	    side_separator: Some(Left),
            name: "keyboard",
            text: "",
            text_size: 11,
            text_color_rgb: (255, 255, 255),
            text_orientation: Horizontal,
            height: 22,
            button_color_rgb: (0, 0, 0),
            button_text_color_rgb: (255, 255, 255),
            button_hovered_color_rgb: (35, 42, 65),
            button_hovered_text_color_rgb: (255, 255, 255),
            button_pressed_color_rgb: (15, 18, 30),
            border_color_rgb: (45, 55, 100),
            border_size: 0.0,
            border_radius: (3.0, 3.0, 3.0, 3.0),
            display_err_output_if_failed: false,
            dont_show_if_any_output_is_empty: true,
            use_output_as_text: false,
            use_continous_output_as_text: true,
            all_output_as_text_format: "{continous_output}",
            output_text_limit_len: 8,
            command_to_exec_on_left_click: ["swaymsg", "input", "type:keyboard", "xkb_switch_layout", "next"],
            command_to_exec_on_right_click: ["swaymsg", "input", "type:keyboard", "xkb_switch_layout", "next"],
            continous_command_interval: 500,
            continous_command: [
                "bash", "-c",
                "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | grep -o '\"[^\"]*\"' | tail -1 | tr -d '\"' | sed 's/English (US)/EN/;s/Russian (N\\/A)/RU/;s/Ukrainian (N\\/A)/UA/' | xargs -I{} echo '{}'"
            ]
        ),

        // ── MODULE 1 ── POWER BUTTON
        (
	    side_separator: Some(Left),
            name: "power",
            text: "󰐥",
            text_size: 17,
            text_color_rgb: (255, 255, 255),
