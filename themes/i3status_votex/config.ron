    // ================= WORKSPACES =================
    // Plain numbers inactive, same numbers active — color alone signals state
    // Active: solid blue bg (45, 90, 195) · Inactive: dim text, ghost bg
    workspace_heigth: 5,
    workspace_width: 3,
    workspace_different_selected_width: None,
    workspace_text_size: 11,
