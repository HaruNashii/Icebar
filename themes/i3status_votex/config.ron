    bar_border_radius: (0., 0., 0., 0.),
    bar_border_size: 0.0,
    bar_border_color_rgb: (8, 57, 132),
    bar_background_color_rgb: (0, 0, 0),

    font_family: "JetBrains Mono",
    font_style: "Bold",


