    // ================= CONTEXT MENU =================
    context_menu:
    (
        context_menu_background_color: RGBA((10, 12, 22, 100)),
        context_menu_background_size: 0,
        context_menu_background_border_color: RGB((255, 255, 255)),
        context_menu_background_border_size: 0.0,
        context_menu_background_border_radius: (3.0, 3.0, 3.0, 3.0),
        context_menu_text_size: 11,
        context_menu_text_color: RGB((255, 255, 255)),
        context_menu_orientation: Vertical,
        context_menu_size: 280,
        context_menu_item_size: 26,
        context_menu_button_color: RGB((0, 0, 0)),
        context_menu_button_hovered_color: RGB((45, 90, 195)),
        context_menu_button_hovered_text_color: RGB((255, 255, 255)),
        context_menu_button_pressed_color: RGB((15, 18, 30)),
        context_menu_border_color: RGB((255, 255, 255)),
        context_menu_border_size: 1.0,
        context_menu_border_radius: (3.0, 3.0, 3.0, 3.0),
    ),


    // ================= FOCUSED WINDOW =================
    focused_window:
    (
        focused_window_format: "{title}",
        focused_window_update_interval: 500,
        dont_show_focused_window_if_empty: false,
        text_when_focused_window_is_empty: "~",
        focused_window_text_limit_len: 85,
        focused_window_padding: 0,
        focused_window_text_size: 11,
        focused_window_text_color: RGB((255, 255, 255)),
        focused_window_text_orientation: Horizontal,
        focused_window_button_color: RGB((0, 0, 0)),
        focused_window_button_hovered_color: RGB((35, 42, 65)),
        focused_window_button_hovered_text_color: RGB((255, 255, 255)),
        focused_window_button_pressed_color: RGB((15, 18, 30)),
        focused_window_border_color: RGB((45, 55, 100)),
        focused_window_border_size: 0.0,
        focused_window_border_radius: (3.0, 3.0, 3.0, 3.0),
        focused_window_side_separator: None,
        focused_window_side_separator_color: RGB((75, 75, 75)),
        focused_window_side_separator_width: 1.,
        focused_window_side_separator_height: 16.,
        focused_window_button_gradient_color: None,
        focused_window_button_hovered_gradient_color: None,
        focused_window_button_pressed_gradient_color: None,
    ),


    // ================= CUSTOM MODULE =================
    custom_module:
    (
        custom_modules_spacing: 0,
        custom_modules:
        [
            (
                side_separator: Some(Left),
                name: "keyboard",
                text: "",
                text_size: 11,
                text_color: RGB((255, 255, 255)),
                text_orientation: Horizontal,
                height: 22,
                button_color: RGB((0, 0, 0)),
                button_hovered_color: RGB((35, 42, 65)),
                button_hovered_text_color: RGB((255, 255, 255)),
                button_pressed_color: RGB((15, 18, 30)),
                border_color: RGB((45, 55, 100)),
                border_size: 0.0,
                border_radius: (3.0, 3.0, 3.0, 3.0),
                display_err_output_if_failed: false,
                dont_show_if_any_output_is_empty: true,
                use_output_as_text: false,
                use_continous_output_as_text: true,
                all_output_as_text_format: "{continous_output}",
                output_text_limit_len: 8,
                command_to_exec_on_left_click: ["swaymsg", "input", "type:keyboard", "xkb_switch_layout", "next"],
                command_to_exec_on_right_click: ["swaymsg", "input", "type:keyboard", "xkb_switch_layout", "next"],
                continous_command_interval: 500,
                continous_command: [
                "bash", "-c",
                "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | grep -o '\"[^\"]*\"' | tail -1 | tr -d '\"' | sed 's/English (US)/EN/;s/Russian (N\\/A)/RU/;s/Ukrainian (N\\/A)/UA/' | xargs -I{} echo '{}'"
            ],
            ),
            (
                side_separator: Some(Left),
                name: "power",
                text: "󰐥",
                text_size: 17,
                text_color: RGB((255, 255, 255)),
                text_orientation: Horizontal,
                height: 14,
                button_color: RGB((0, 0, 0)),
                button_hovered_color: RGB((80, 25, 40)),
                button_hovered_text_color: RGB((255, 255, 255)),
                button_pressed_color: RGB((15, 18, 30)),
                border_color: RGB((45, 55, 100)),
                border_size: 0.0,
                border_radius: (3.0, 3.0, 3.0, 3.0),
                display_err_output_if_failed: false,
                dont_show_if_any_output_is_empty: false,
                use_output_as_text: false,
                use_continous_output_as_text: false,
                all_output_as_text_format: "",
                output_text_limit_len: 0,
                command_to_exec_on_left_click: ["wleave"],
                command_to_exec_on_right_click: ["wleave"],
                continous_command_interval: 500,
