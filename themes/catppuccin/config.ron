BarConfig
(

    // ================= GENERAL =================
    general:
    (
        display: None,
        bar_position: Up,
        floating_space: 10,
        increased_exclusive_bar_zone: 10,
        bar_check_reload_interval_ms: Some(500),
        bar_side_spaces_size: 10,
        bar_size: (1900, 35),
        bar_border_radius: (8., 8., 8., 8.),
        bar_border_size: 0.,
        bar_border_color: RGB((90, 70, 100)),
        bar_background_color: RGBA((24, 24, 37, 0)),
        font_family: "JetBrains Mono",
        font_style: "Bold",
        spacing_between_all_modules: 5,
        force_static_position_context_menu: None,
        left_modules: [HyprWorkspaces, CustomModule(0)],
        center_modules: [Clock, MediaPlayerMetaData, MediaPlayerButtons],
        right_modules: [Tray, Network, VolumeOutput, VolumeInput],
    ),


