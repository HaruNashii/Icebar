        clock_button_pressed_color: RGB((245, 194, 231)),
        clock_border_color: RGB((120, 80, 130)),
        clock_border_size: 0.,
        clock_border_radius: (6.0, 6.0, 6.0, 6.0),
        alt_clock_padding: 0,
        alt_clock_text_size: 15,
        alt_clock_text_color: RGB((0, 0, 0)),
        alt_clock_text_orientation: Horizontal,
        alt_clock_button_color: RGB((180, 190, 254)),
        alt_clock_button_hovered_color: RGB((203, 166, 247)),
        alt_clock_button_hovered_text_color: RGB((30, 30, 46)),
        alt_clock_button_pressed_color: RGB((245, 194, 231)),
        alt_clock_border_color: RGB((120, 80, 130)),
        alt_clock_border_size: 0.,
        alt_clock_border_radius: (6.0, 6.0, 6.0, 6.0),
    ),


