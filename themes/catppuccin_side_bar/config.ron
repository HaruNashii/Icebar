// ╭─────────────────────────────────────────────────────────────────────────╮
// │                                                                         │
// │   C A T P P U C C I N   M O C H A   ·   ICEBAR                         │
// │   Vertical left sidebar. The r/unixporn special.                        │
// │                                                                         │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE — official Catppuccin Mocha values
//
//    Base     ( 30,  30,  46)  ← deepest bg
//    Mantle   ( 24,  24,  37)  ← darker layer
//    Crust    ( 17,  17,  27)  ← bar background
//    Surface0 ( 49,  50,  68)  ← module resting bg
//    Surface1 ( 69,  71,  90)  ← hover bg
//    Surface2 ( 88,  91, 112)  ← dim text / borders if ever used
//    Overlay0 (108, 112, 134)  ← muted text
//    Overlay2 (147, 153, 178)  ← subtext
//    Text     (205, 214, 244)  ← primary text
//    Subtext1 (186, 194, 222)  ← secondary text
//
//    Accents (the pastels):
//    Rosewater (245, 224, 220)
//    Flamingo  (242, 205, 205)
//    Pink      (245, 194, 231)
//    Mauve     (203, 166, 247)  ← PRIMARY ACCENT — workspaces, clock, badge
//    Red       (243, 139, 168)  ← muted audio
//    Maroon    (235, 160, 172)
//    Peach     (250, 179, 135)  ← secondary accent — media player
//    Yellow    (249, 226, 175)
//    Green     (166, 227, 161)  ← network ok
//    Teal      (148, 226, 213)  ← volume
//    Sky       (137, 220, 235)
//    Sapphire  (116, 199, 236)
//    Blue      (137, 180, 250)  ← tertiary accent
//    Lavender  (180, 190, 254)  ← selected workspace text
//
//  DESIGN:
//    · LEFT SIDE BAR — vertical orientation, 46px wide, full height
//    · Modules stacked top-to-bottom with text in Vertical orientation
//    · Workspaces run vertically down the left edge — classic unixporn look
//    · No borders anywhere — pure color contrast only
//    · Generous border radius (10px) — soft, cozy, Catppuccin DNA
//    · Font: JetBrains Mono Bold — the unixporn staple
//    · Clock centered vertically in the bar
//    · Mauve is the single unifying accent across all active states
//    · Each module group uses a different pastel for its text — colorful
//      but never clashing because they all share the same dark base

BarConfig
(
    // ================= GENERAL =================
    display: None,
    bar_position: Left,
    floating_space: 6,
    increased_exclusive_bar_zone: 0,
    bar_side_spaces_size: 6,
    bar_size: (46, 0),                                // 46px wide, full height

    bar_border_radius: (10., 10., 10., 10.),
    bar_border_size: 0.0,
    bar_border_color: RGB((0, 0, 0)),
    bar_background_color: RGBA((17, 17, 27, 100)),      // Crust — deepest layer

    font_family: "JetBrains Mono",
    font_style: "Bold",


    // ================= GENERAL (STYLE) =================
    //general_padding: Some(0),
    //general_text_size: Some(15),
    //general_text_orientation: Some(Horizontal),
    //general_text_color: Some(RGB((255, 255, 255))),
    //general_button_color: Some(RGB((50, 45, 60))),
    //general_button_hovered_color: Some(RGB((130, 35, 70))),
    //general_button_hovered_text_color: Some(RGB((255, 255, 255))),
    //general_button_pressed_color: Some(RGB((80, 25, 45))),
    //general_border_color: Some(RGB((120, 80, 130))),
    //general_border_size: Some(1.0),
    //general_border_radius: Some((3.0, 3.0, 3.0, 3.0)),
    //general_side_separator: None,
    //general_side_separator_color: Some(RGB((75, 75, 75))),
    //general_side_separator_width: Some(1.0),
    //general_side_separator_height: Some(16.0),
    //general_alt_padding: None,
    //general_alt_text_size: None,
    //general_alt_text_orientation: None,
    //general_alt_text_color: None,
    //general_alt_button_color: None,
    //general_alt_button_hovered_color: None,
    //general_alt_button_hovered_text_color: None,
    //general_alt_button_pressed_color: None,
    //general_alt_border_color: None,
    //general_alt_border_size: None,
    //general_alt_border_radius: None,
    //general_alt_side_separator: None,
    //general_alt_side_separator_color: None,
    //general_alt_side_separator_width: None,
    //general_alt_side_separator_height: None,


    // ================= MODULES =================
    left_modules:  [CustomModule(0), NiriWorkspaces],
    center_modules:[Clock],
    right_modules: [VolumeOutput, VolumeInput, Network, Tray],


    // ================= MODULES CONFIGS =================
    ellipsis_text: "…",
    player: "spotify",
    dont_show_metadata_if_empty: true,
    text_when_metadata_is_empty: "~",
    media_player_metadata_text_limit_len: 18,         // short — vertical space is precious
    spacing_between_all_modules: 8,
    force_static_position_context_menu: None,
    reverse_scroll_on_workspace: false,
    persistent_workspaces: Some(6),
    incremental_steps_output: 5,
    incremental_steps_input: 5,
    action_on_left_click_media_player_metadata: DefaultAction,
    action_on_right_click_media_player_metadata: DefaultAction,
    action_on_left_click_clock: Nothing,
    action_on_right_click_clock: CustomAction(["kitty", "bash", "-c", "cal && echo '' && read -n 1"]),
    action_on_left_click_network: Nothing,
    action_on_right_click_network: Nothing,
    action_on_left_click_volume_output: DefaultAction,
    action_on_right_click_volume_output: CustomAction(["kitty", "pulsemixer"]),
    action_on_left_click_volume_input: DefaultAction,
    action_on_right_click_volume_input: CustomAction(["kitty", "pulsemixer"]),


    // ================= FORMATS =================
    media_player_buttons_format: ("󰒮", "󰏤", "󰐊", "󰒭"),
    media_player_metadata_format: "{{title}}",        // title only — sidebar is narrow

    network_disconnected_text: "󰤭",
    network_module_format: "{level}    ",
    alt_network_module_format: "{level}",
    network_level_format:
    (
        "󰤨",
        "󰤥",
        "󰤢",
        "󰤭"
    ),
    network_connection_type_icons: ("󰈀", "󰤨", "󰤭"),

    output_volume_format:
    (
        "󰕿",
        "󰕿",
        "󰖀",
        "󰖀",
        "󰕾",
        "󰕾"
    ),
    input_volume_format:
    (
        "󰍭",
        "󰍬",
        "󰍬",
        "󰍬",
        "󰍬",
        "󰍬"
    ),
    output_volume_muted_format: "󰝟",
    input_volume_muted_format:  "󰍭",

    clock_format:     "%H-%M",                       // hour on top, minutes below — vertical clock
    clock_alt_format: "%H-%M",


    // ================= TRAY =================
    tray_icon_size: 20,
    tray_spacing: 6,
    tray_button_size: 6,
    tray_button_color: RGB((49, 50, 68)),
    tray_button_hovered_color: RGB((69, 71, 90)),
    tray_button_hovered_text_color: RGB((205, 214, 244)),
    tray_button_pressed_color: RGB((24, 24, 37)),
    tray_border_color: RGB((0, 0, 0)),
    tray_border_size: 0.0,
    tray_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= MEDIA PLAYER METADATA =================
    // Peach — warm, music-like, glows against the dark sidebar
    media_player_metadata_text_size: 12,
    media_player_metadata_text_color: RGB((250, 179, 135)),   // Peach
    media_player_metadata_text_orientation: Vertical,
    media_player_metadata_button_color: RGB((49, 50, 68)),
    media_player_metadata_button_hovered_color: RGB((69, 71, 90)),
    media_player_metadata_button_hovered_text_color: RGB((250, 179, 135)),
    media_player_metadata_button_pressed_color: RGB((24, 24, 37)),
    media_player_metadata_border_color: RGB((0, 0, 0)),
    media_player_metadata_border_size: 0.0,
    media_player_metadata_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= MEDIA PLAYER BUTTONS =================
    media_player_button_spacing: 5,
    media_player_button_text_size: 16,
    media_player_button_text_orientation: Vertical,
    media_player_button_color: RGB((49, 50, 68)),
    media_player_button_hovered_color: RGB((69, 71, 90)),
    media_player_button_hovered_text_color: RGB((203, 166, 247)),
    media_player_button_pressed_color: RGB((24, 24, 37)),
    media_player_button_border_color: RGB((0, 0, 0)),
    media_player_button_border_size: 0.0,
    media_player_button_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= NETWORK =================
    // Green — a signal is alive, healthy
    network_text_size: 15,
    network_text_color: RGB((166, 227, 161)),          // Green
    network_text_orientation: Horizontal,
    network_button_color: RGB((49, 50, 68)),
    network_button_hovered_color: RGB((69, 71, 90)),
    network_button_hovered_text_color: RGB((166, 227, 161)),
    network_button_pressed_color: RGB((24, 24, 37)),
    network_border_color: RGB((0, 0, 0)),
    network_border_size: 0.0,
    network_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= CLOCK =================
    // The centerpiece of the sidebar. Large Mauve digits stacked vertically.
    // HH on top, MM below — iconic vertical clock look.
    clock_text_size: 18,
    clock_text_color: RGB((203, 166, 247)),            // Mauve — the accent
    clock_text_orientation: Vertical,
    clock_button_color: RGB((30, 30, 46)),             // Base — slightly lifted from Crust
    clock_button_hovered_color: RGB((49, 50, 68)),
    clock_button_hovered_text_color: RGB((203, 166, 247)),
    clock_button_pressed_color: RGB((24, 24, 37)),
    clock_border_color: RGB((0, 0, 0)),
    clock_border_size: 0.0,
    clock_border_radius: (10.0, 10.0, 10.0, 10.0),

    // ================= ALT CLOCK =================
    alt_clock_text_size: 14,
    alt_clock_text_color: RGB((180, 190, 254)),        // Lavender
    alt_clock_text_orientation: Vertical,
    alt_clock_button_color: RGB((49, 50, 68)),
    alt_clock_button_hovered_color: RGB((69, 71, 90)),
    alt_clock_button_hovered_text_color: RGB((180, 190, 254)),
    alt_clock_button_pressed_color: RGB((24, 24, 37)),
    alt_clock_border_color: RGB((0, 0, 0)),
    alt_clock_border_size: 0.0,
    alt_clock_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= VOLUME OUTPUT =================
    // Teal — cool, clean, technical
    volume_output_text_size: 16,
    volume_output_text_color: RGB((148, 226, 213)),    // Teal
    volume_output_text_orientation: Vertical,
    volume_output_button_color: RGB((49, 50, 68)),
    volume_output_button_hovered_color: RGB((69, 71, 90)),
    volume_output_button_hovered_text_color: RGB((148, 226, 213)),
    volume_output_button_pressed_color: RGB((24, 24, 37)),
    volume_output_border_color: RGB((0, 0, 0)),
    volume_output_border_size: 0.0,
    volume_output_border_radius: (8.0, 8.0, 8.0, 8.0),

    // ================= MUTED VOLUME OUTPUT =================
    muted_volume_output_text_size: 16,
    muted_volume_output_text_color: RGB((243, 139, 168)),  // Red
    muted_volume_output_text_orientation: Vertical,
    muted_volume_output_button_color: RGB((49, 50, 68)),
    muted_volume_output_button_hovered_color: RGB((69, 71, 90)),
    muted_volume_output_button_hovered_text_color: RGB((243, 139, 168)),
    muted_volume_output_button_pressed_color: RGB((24, 24, 37)),
    muted_volume_output_border_color: RGB((0, 0, 0)),
    muted_volume_output_border_size: 0.0,
    muted_volume_output_border_radius: (8.0, 8.0, 8.0, 8.0),

    // ================= VOLUME INPUT =================
    volume_input_text_size: 16,
    volume_input_text_color: RGB((148, 226, 213)),
    volume_input_text_orientation: Vertical,
    volume_input_button_color: RGB((49, 50, 68)),
    volume_input_button_hovered_color: RGB((69, 71, 90)),
    volume_input_button_hovered_text_color: RGB((148, 226, 213)),
    volume_input_button_pressed_color: RGB((24, 24, 37)),
    volume_input_border_color: RGB((0, 0, 0)),
    volume_input_border_size: 0.0,
    volume_input_border_radius: (8.0, 8.0, 8.0, 8.0),

    // ================= MUTED VOLUME INPUT =================
    muted_volume_input_text_size: 16,
    muted_volume_input_text_color: RGB((243, 139, 168)),
    muted_volume_input_text_orientation: Vertical,
    muted_volume_input_button_color: RGB((49, 50, 68)),
    muted_volume_input_button_hovered_color: RGB((69, 71, 90)),
    muted_volume_input_button_hovered_text_color: RGB((243, 139, 168)),
    muted_volume_input_button_pressed_color: RGB((24, 24, 37)),
    muted_volume_input_border_color: RGB((0, 0, 0)),
    muted_volume_input_border_size: 0.0,
    muted_volume_input_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= WORKSPACES =================
    // Vertical dot indicators — the classic unixporn sidebar workspace column.
    // Inactive = dim surface, barely visible.
    // Active = Mauve filled pill, Lavender text.
    // Hovered = Surface1 lift.
    workspace_height: 30,
    workspace_width: 30,
    workspace_different_selected_width: None,
    workspace_text_size: 12,
    workspace_text_color: RGB((108, 112, 134)),        // Overlay0 — dim when inactive
    workspace_selected_text_color: RGB((148, 226, 213)),
    workspace_text_orientation: Vertical,
    workspace_text:
    [
        "󰊠", "󰊠", "󰊠", "󰊠", "󰊠", "󰊠", "󰊠", "󰊠", "󰊠", "󰊠"
    ],
    workspace_selected_text: Some(
    [
        "󰊡", "󰊡", "󰊡", "󰊡", "󰊡", "󰊡", "󰊡", "󰊡", "󰊡", "󰊡"
    ]),
    workspace_spacing: 4,
    workspace_button_color: RGB((30, 30, 46)),         // Base — nearly invisible resting
    workspace_button_selected_color: RGB((49, 50, 68)),// Surface0 — subtle lift when active
    workspace_button_hovered_color: RGB((69, 71, 90)),
    workspace_button_hovered_text_color: RGB((203, 166, 247)),  // Mauve on hover
    workspace_button_pressed_color: RGB((24, 24, 37)),
    workspace_border_color: RGB((0, 0, 0)),
    workspace_border_size: 0.0,
    workspace_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= CONTEXT MENU =================
    context_menu_background_color: RGBA((24, 24, 37, 100)),   // Mantle
    context_menu_background_size: 6,
    context_menu_background_border_color: RGB((0, 0, 0)),
    context_menu_background_border_size: 0.0,
    context_menu_background_border_radius: (10.0, 10.0, 10.0, 10.0),
    context_menu_text_size: 13,
    context_menu_text_color: RGB((205, 214, 244)),
    context_menu_orientation: Vertical,
    context_menu_size: 240,
    context_menu_item_size: 30,
    context_menu_button_color: RGB((30, 30, 46)),
    context_menu_button_hovered_color: RGB((69, 71, 90)),
    context_menu_button_hovered_text_color: RGB((205, 214, 244)),
    context_menu_button_pressed_color: RGB((24, 24, 37)),
    context_menu_border_color: RGB((0, 0, 0)),
    context_menu_border_size: 0.0,
    context_menu_border_radius: (8.0, 8.0, 8.0, 8.0),


    // ================= CUSTOM MODULES =================
    custom_modules_spacing: 8,
    custom_modules:
    [
        // ── MODULE 0 ── DISTRO BADGE
        // A small Mauve pill at the very top of the sidebar.
        // Just a nerd font distro icon — no text, no noise.
        // The logo of your setup. Left-click = wofi drun.
        (
            name: "distro",
            text: "󰣇    ",                               // Arch logo — change to your distro
            text_size: 15,
            text_color: RGB((166, 227, 161)),          // Green 
            text_orientation: Vertical,
            height: 36,
            button_color: RGB((49, 50, 68)),           // Surface0 — sits quietly
            button_hovered_color: RGB((69, 71, 90)),
            button_hovered_text_color: RGB((245, 224, 220)),  // Rosewater on hover — a wink
            button_pressed_color: RGB((24, 24, 37)),
            border_color: RGB((0, 0, 0)),
            border_size: 0.0,
            border_radius: (10.0, 10.0, 10.0, 10.0),
            display_err_output_if_failed: false,
            dont_show_if_any_output_is_empty: false,
            use_output_as_text: false,
            use_continous_output_as_text: false,
            all_output_as_text_format: "",
            output_text_limit_len: 0,
            command_to_exec_on_left_click: ["wofi", "--show", "drun"],
            command_to_exec_on_right_click: ["wofi", "--show", "run"],
            continous_command_interval: 500,
            continous_command: []
        ),
    ],
)
