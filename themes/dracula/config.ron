        alt_clock_text_color: RGB((80, 250, 123)),
        alt_clock_text_orientation: Horizontal,
        alt_clock_button_color: RGB((68, 71, 90)),
        alt_clock_button_hovered_color: RGB((255, 121, 198)),
        alt_clock_button_hovered_text_color: RGB((40, 42, 54)),
