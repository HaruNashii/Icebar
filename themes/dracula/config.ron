// ╭─────────────────────────────────────────────────────────────────────────╮
// │                                                                         │
// │   D R A C U L A   v2   ·   ICEBAR                                       │
// │   Bottom island. Media left. Workspaces center. Clock right.            │
// │   Everything the first one wasn't.                                      │
// │                                                                         │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE — official Dracula
//
//    background  ( 40,  42,  54)
//    currentLine ( 68,  71,  90)
//    foreground  (248, 248, 242)
//    comment     ( 98, 114, 164)
//    cyan        (139, 233, 253)
//    green       ( 80, 250, 123)
//    orange      (255, 184, 108)
//    pink        (255, 121, 198)  ← PRIMARY ACCENT
//    purple      (189, 147, 249)
//    red         (255,  85,  85)
//    yellow      (241, 250, 140)
//
//  DESIGN — inverted from v1 in every way:
//    · BOTTOM FLOATING ISLAND — bar_size: (1100, 44), floating_space: 10
//    · No badge module, no launcher — bar opens with media player buttons
//    · Layout: LEFT=MediaPlayerButtons  CENTER=Workspaces  RIGHT=VolumeOutput+Network+Clock
//    · Clock is on the FAR RIGHT — reads last, like a timestamp
//    · Workspaces use large uppercase letters (A B C D E) not numbers
//    · Massive border_radius: (22., 22., 22., 22.) — the island is a huge pill
//    · Modules: 12px radius — nested softness inside the outer pill
//    · font: "Fira Code" Bold — distinct from v1's JetBrains
//    · Clock text is GREEN (not cyan like v1) — swapped roles
//    · Network text is YELLOW — never used in v1
//    · Volume text is ORANGE
//    · Media buttons in PURPLE — the opener of the bar
//    · Pink owns only workspaces selected + hover — focused role

BarConfig
(

    // ================= GENERAL =================
    general:
    (
        display: None,
        bar_position: Down,
        floating_space: 10,
        increased_exclusive_bar_zone: 0,
        bar_check_reload_interval_ms: Some(500),
        bar_side_spaces_size: 10,
        bar_size: (1100, 44),
        bar_border_radius: (22., 22., 22., 22.),
        bar_border_size: 0.0,
        bar_border_color: RGB((0, 0, 0)),
        bar_background_color: RGBA((40, 42, 54, 100)),
        font_family: "Fira Code",
        font_style: "Bold",
        spacing_between_all_modules: 8,
        force_static_position_context_menu: None,
        left_modules: [MediaPlayerButtons, MediaPlayerMetaData],
        center_modules: [HyprWorkspaces],
        right_modules: [VolumeOutput, VolumeInput, Network, Clock],
    ),


    // ================= GENERAL STYLE =================
