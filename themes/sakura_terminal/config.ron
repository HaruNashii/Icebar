        clock_button_pressed_gradient_color: None,
        alt_clock_button_gradient_color: None,
        alt_clock_button_hovered_gradient_color: None,
        alt_clock_button_pressed_gradient_color: None,
        clock_padding: 0,
        clock_text_size: 16,
        clock_text_color: RGB((38, 32, 28)),
        clock_text_orientation: Horizontal,
        clock_button_color: RGB((252, 248, 241)),
        clock_button_hovered_color: RGB((210, 105, 60)),
        clock_button_hovered_text_color: RGB((252, 248, 241)),
        clock_button_pressed_color: RGB((170, 80, 40)),
        clock_border_color: RGB((185, 160, 130)),
        clock_border_size: 0.0,
        clock_border_radius: (0.0, 0.0, 0.0, 0.0),
        alt_clock_padding: 0,
        alt_clock_text_size: 14,
        alt_clock_text_color: RGB((38, 32, 28)),
        alt_clock_text_orientation: Horizontal,
        alt_clock_button_color: RGB((244, 239, 230)),
        alt_clock_button_hovered_color: RGB((210, 105, 60)),
        alt_clock_button_hovered_text_color: RGB((252, 248, 241)),
        alt_clock_button_pressed_color: RGB((170, 80, 40)),
        alt_clock_border_color: RGB((185, 160, 130)),
        alt_clock_border_size: 1.0,
        alt_clock_border_radius: (5.0, 5.0, 5.0, 5.0),
    ),


    // ================= VOLUME OUTPUT =================
    volume_output:
