            output_text_limit_len: 28,
            command_to_exec_on_left_click: ["kitty", "bash", "-c", "btop"],
            command_to_exec_on_right_click: ["kitty", "bash", "-c", "htop"],
            continous_command_interval: 1500,
            continous_command: [
                "bash", "-c",
                "cpu=$(top -bn1 | grep 'Cpu(s)' | awk '{print $2}' | cut -d. -f1); ram=$(free -m | awk '/Mem:/{printf \"%dM/%dM\", $3, $2}'); echo \"CPU ${cpu}%  RAM ${ram}\""
            ]
        ),

        // ‚ĒÄ‚ĒÄ MODULE 2 ‚ĒÄ‚ĒÄ PLAYERCTL NOW PLAYING
        // Scrolling artist + title from any player. Cyan color.
        // Left-click = play/pause. Right-click = next track.
        (
            name: "NOW_PLAYING",
            text: "",
            text_size: 12,
            text_color_rgb: (0, 220, 255),
            text_orientation: Horizontal,
            height: 26,
            button_color_rgb: (8, 18, 28),
            button_text_color_rgb: (0, 220, 255),
            button_hovered_color_rgb: (255, 0, 110),
            button_hovered_text_color_rgb: (5, 5, 8),
            button_pressed_color_rgb: (0, 140, 200),
            border_color_rgb: (0, 220, 255),
            border_size: 1.0,
            border_radius: (0.0, 0.0, 0.0, 0.0),
            display_err_output_if_failed: false,
            dont_show_if_any_output_is_empty: true,
            use_output_as_text: false,
            use_continous_output_as_text: true,
            all_output_as_text_format: "‚ô™ {continous_output}",
            output_text_limit_len: 35,
            command_to_exec_on_left_click: ["playerctl", "play-pause"],
            command_to_exec_on_right_click: ["playerctl", "next"],
            continous_command_interval: 1000,
            continous_command: ["playerctl", "metadata", "--format", "{{ artist }} ‚üę {{ title }}"]
        ),
    ],
)
