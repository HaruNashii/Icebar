        bar_border_color: RGB((0, 255, 140)),
        bar_background_color: RGBA((5, 5, 8, 100)),
        font_family: "JetBrains Mono",
        font_style: "Bold",
        spacing_between_all_modules: 4,
        force_static_position_context_menu: None,
        left_modules: [CustomModule(0), HyprWorkspaces, Cpu, Ram],
        center_modules: [Clock, MediaPlayerMetaData, MediaPlayerButtons],
        right_modules: [Network, VolumeOutput, VolumeInput, Tray],
    ),


